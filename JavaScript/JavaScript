document.addEventListener('DOMContentLoaded', () => {
    console.log('JavaScript successfully connected!');

    // 1. DYNAMIC WELCOME GREETING
    // Automatically updates based on the user's local time of day
    const welcomeHeading = document.querySelector('#welcome-message');
    if (welcomeHeading) {
        const hours = new Date().getHours();
        let greeting = 'Welcome to Kay & Kay Student Living';
        
        if (hours < 12) {
            greeting = 'Good Morning! Welcome to Kay & Kay Student Living';
        } else if (hours < 18) {
            greeting = 'Good Afternoon! Welcome to Kay & Kay Student Living';
        } else {
            greeting = 'Good Evening! Welcome to Kay & Kay Student Living';
        }
        
        welcomeHeading.textContent = greeting;
    }

    // 2. CONTACT FORM CONFIRMATION
    // Handles the inquiry submission behavior for your room prices
    const contactForm = document.querySelector('form');
    if (contactForm) {
        contactForm.addEventListener('submit', function(event) {
            // Displays an immediate success confirmation pop-up to the student
            alert('Thank you for your inquiry! A price list has been sent to your email, and our team will contact you shortly.');
        });
    }
});
